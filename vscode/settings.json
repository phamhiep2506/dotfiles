// Extensions
// vscodevim.vim
// jdinhlife.gruvbox
// usernamehw.errorlens
// EditorConfig.EditorConfig
// ms-dotnettools.csdevkit
// miguelsolorio.symbols
// drcika.apc-extension
// christian-kohler.path-intellisense
{
    // Disable welcome
    "workbench.startupEditor": "none",
    // Colorscheme
    "workbench.colorTheme": "Gruvbox Dark Hard",
    // Editor
    "editor.fontFamily": "JetBrains Mono",
    "editor.fontSize": 15,
    "editor.fontLigatures": true,
    "editor.lineHeight": 1.6,
    "editor.rulers": [80, 120],
    "editor.minimap.enabled": false,
    "editor.renderLineHighlight": "gutter",
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.horizontal": "hidden",
    "editor.folding": false,
    "breadcrumbs.enabled": false,
    // Smooth
    "editor.smoothScrolling": true,
    "editor.cursorSmoothCaretAnimation": "on",
    // File
    "files.trimTrailingWhitespace": true,
    // Icon
    "workbench.iconTheme": "symbols",
    "symbols.hidesExplorerArrows": false,
    // Window
    "window.menuBarVisibility": "toggle",
    "window.customTitleBarVisibility": "never",
    "workbench.activityBar.location": "bottom",
    // Extension
    "extensions.ignoreRecommendations": true,
    // Explorer
    "explorer.compactFolders": false,
    // Apc
    "apc.font.family": "JetBrains Mono",
    "apc.listRow": {
        "height": 24,
        "fontSize": 14
    },
    "apc.statusBar": {
        "position": "editor-bottom",
    },
    "apc.stylesheet": {
        ".editor-actions": "display: none",
        ".title-actions": "display: none",
        ".scrollbar.vertical": "display: none",
        ".decorationsOverviewRuler": "display: none !important"
    },
    // Custom color
    "workbench.colorCustomizations": {
        "errorLens.errorBackground": "#ffffff00",
        "errorLens.warningBackground":"#ffffff00",
        "errorLens.infoBackground":"#ffffff00",
        "errorLens.hintBackground":"#ffffff00",
    },
    // Error lens
    "errorLens.gutterIconsEnabled": true,
    "errorLens.messageTemplate": "● $message",
    // Vim
    "vim.leader": "<space>",
    "vim.easymotion": true,
    "vim.useCtrlKeys": true,
    "vim.incsearch": true,
    "vim.hlsearch": true,
    "vim.useSystemClipboard": false,
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1
    },
    "vim.normalModeKeyBindings": [
        // Fuzzy file
        {
            "before": ["<leader>", "f", "f"],
            "commands": ["workbench.action.quickOpen"]
        },
        {
            "before": ["<leader>", "f", "b"],
            "commands": ["workbench.action.showAllEditors"]
        },
        // Jump
        {
            "before": ["j"],
            "after": ["j", "z", "z"]
        },
        {
            "before": ["k"],
            "after": ["k", "z", "z"]
        },
        {
            "before": ["J"],
            "after": [5, "j", "z", "z"]
        },
        {
            "before": ["K"],
            "after": [5, "k", "z", "z"]
        },
        // Search
        {
            "before": ["<leader>", "Enter"],
            "commands": [":nohlsearch"]
        },
        {
            "before": ["n"],
            "after": ["n", "z", "z"]
        },
        {
            "before": ["N"],
            "after": ["N", "z", "z"]
        },
        // Paste
        {
            "before": ["<leader>", "p"],
            "after": ["\"", "+", "p"]
        },
        // Split
        {
            "before": ["<leader>", "_"],
            "commands": [":split"]
        },
        {
            "before": ["<leader>", "|"],
            "commands": [":vsplit"]
        },
    ],
    "vim.visualModeKeyBindings": [
        // Indent
        {
            "before": [">"],
            "after": [">", "g", "v"]
        },
        {
            "before": ["<"],
            "after": ["<", "g", "v"]
        },
        // Copy & Paste
        {
            "before": ["<leader>", "p"],
            "after": ["\"", "+", "p"]
        },
        {
            "before": ["<leader>", "y"],
            "after": ["\"", "+", "y"]
        },
    ],
}
