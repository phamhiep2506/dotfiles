#
# wm hotkeys
#

# terminal
super + shift + Return
	alacritty

# launcher
super + p
	rofi -show drun

# reload sxhkd
super + Escape
	pkill -USR1 -x sxhkd

#
# bspwm hotkeys
#

# quit bspwm
super + shift + q
	bspc quit

# restart bspwm
super + shift + r
	bspc wm --restart

# kill window
super + shift + c
	bspc node --kill

#
# state window
#

# set window tiled
super + t
	bspc node --state tiled

# set window floating
super + f
	bspc node --state floating

# set window floating
super + shift + f
	bspc node --state fullscreen

#
# focus/swap window & desktop
#

# focus window
super + {h,j,k,l}
	bspc node --focus {west,south,north,east}

# swap window
super + shift + {h,j,k,l}
	bspc node --swap {west,south,north,east}

# focus last desktop
super + Tab
	bspc desktop --focus last

# focus desktop
super + {1-9}
	bspc desktop --focus ^{1-9}

# send to desktop
super + shift + {1-9}
	bspc node --to-desktop ^{1-9}

#
# preselect
#

# preselect the direction
super + ctrl + {h,j,k,l}
	bspc node --presel-dir {west,south,north,east}

# cancel preselect
super + ctrl + space
	bspc node --presel-dir cancel

#
# move/resize window
#

# resize window
super + alt + {h,j,k,l}
	bspc node --resize {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# move floating window
super + {Left,Down,Up,Right}
	bspc node --move {-20 0,0 20,0 -20,20 0}
